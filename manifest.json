{
  "manifest_version": 3,
  "name": "dataLayer Logger",
  "version": "2.0",
  "description": "Записывает dataLayer пуши с реальными скриншотами страницы",
  "permissions": ["tabs", "storage", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "dataLayer Logger"
  }
}
